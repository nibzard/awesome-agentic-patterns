---
interface Props {
  title: string;
  slug: string;
  summary?: string;
  status?: string;
  category?: string;
  tags?: string[];
}

const {
  title,
  slug,
  summary,
  status = 'proposed',
  category = 'Uncategorized',
  tags = [],
} = Astro.props;

const statusColors: Record<string, string> = {
  proposed: 'var(--color-text-muted)',
  emerging: 'var(--color-accent-blue)',
  established: 'var(--color-primary)',
  'validated-in-production': 'var(--color-success)',
  'best-practice': 'var(--color-success)',
  'experimental-but-awesome': 'var(--color-warning)',
  'rapidly-improving': 'var(--color-accent-blue)',
};

const categoryColors: Record<string, string> = {
  'Orchestration & Control': 'var(--color-accent-blue)',
  'Context & Memory': 'var(--color-accent-moss)',
  'Feedback Loops': 'var(--color-primary)',
  'Learning & Adaptation': 'var(--color-warning)',
  'Reliability & Eval': 'var(--color-accent-blue)',
  'Security & Safety': 'var(--color-primary)',
  'Tool Use & Environment': 'var(--color-accent-amber)',
  'UX & Collaboration': 'var(--color-accent-moss)',
};

const statusLabel = status.replace(/-/g, ' ');
---

<article
  class="pattern-card"
  style={`--status-color: ${statusColors[status] || 'var(--color-text-muted)'}; --category-color: ${categoryColors[category] || 'var(--color-primary)'}`}
>
  <a href={`/patterns/${slug}`} class="pattern-card-link">
    <div class="pattern-card-topline">
      <span class="pattern-card-category">{category}</span>
      <span class="pattern-card-status">{statusLabel}</span>
    </div>

    <h3 class="pattern-card-title">{title}</h3>

    {summary && <p class="pattern-card-summary">{summary}</p>}

    <div class="pattern-card-footer">
      <span class="pattern-card-readmore">Open pattern</span>
      {
        tags.length > 0 && (
          <div class="pattern-card-tags">
            {tags.slice(0, 2).map((tag) => (
              <span class="pattern-card-tag">{tag}</span>
            ))}
          </div>
        )
      }
    </div>
  </a>
</article>

<style>
  .pattern-card {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: rgba(255, 250, 242, 0.72);
    border: 1px solid rgba(182, 164, 143, 0.5);
    box-shadow: var(--shadow-sm);
    backdrop-filter: blur(12px);
  }

  .pattern-card::before {
    content: '';
    position: absolute;
    inset: 0 auto auto 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, var(--category-color), transparent 78%);
  }

  .pattern-card:hover {
    transform: translateY(-2px);
    border-color: var(--category-color);
    box-shadow: var(--shadow-md);
  }

  .pattern-card-link {
    display: block;
    padding: 1.35rem;
    min-height: 100%;
  }

  .pattern-card-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-md);
  }

  .pattern-card-category,
  .pattern-card-status {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pattern-card-category {
    color: var(--category-color);
  }

  .pattern-card-status {
    color: var(--status-color);
    text-align: right;
  }

  .pattern-card-title {
    font-size: clamp(1.2rem, 2vw, 1.45rem);
    line-height: 1.1;
  }

  .pattern-card-summary {
    margin: var(--spacing-md) 0 var(--spacing-lg);
    color: var(--color-text-muted);
    font-size: 0.94rem;
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .pattern-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    margin-top: auto;
  }

  .pattern-card-readmore {
    color: var(--color-text);
    font-weight: 600;
  }

  .pattern-card-tags {
    display: flex;
    gap: var(--spacing-xs);
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .pattern-card-tag {
    padding: 0.18rem 0.5rem;
    border-radius: 999px;
    background: rgba(50, 93, 150, 0.08);
    color: var(--color-text-muted);
    font-size: 0.74rem;
  }

  @media (max-width: 640px) {
    .pattern-card-footer,
    .pattern-card-topline {
      flex-direction: column;
      align-items: flex-start;
    }

    .pattern-card-tags {
      justify-content: flex-start;
    }
  }
</style>
