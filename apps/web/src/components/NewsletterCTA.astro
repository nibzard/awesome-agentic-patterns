---
// ABOUTME: NewsletterCTA component - A reusable newsletter subscription form component

interface Props {
  variant?: 'default' | 'compact' | 'banner' | 'minimal';
  title?: string;
  description?: string;
  buttonText?: string;
}

const {
  variant = 'default',
  title = 'Stay Updated',
  description = 'Get notified when we add new patterns or publish guides.',
  buttonText = 'Subscribe',
} = Astro.props;
---

<div class={`newsletter-cta newsletter-cta--${variant}`}>
  <div class="newsletter-cta-content">
    <h3 class="newsletter-cta-title">{title}</h3>
    {variant !== 'compact' && <p class="newsletter-cta-description">{description}</p>}
  </div>
  <form
    class="newsletter-cta-form"
    data-newsletter-form
    data-nonce={Math.random().toString(36).substring(7)}
  >
    {variant === 'minimal' && <p class="newsletter-cta-invite">Get new patterns in your inbox</p>}
    <div class="newsletter-cta-input-group">
      <input
        type="email"
        name="email"
        placeholder="your@email.com"
        required
        class="newsletter-cta-input"
        aria-label="Email address"
      />
      <button type="submit" class="newsletter-cta-button">
        <span class="newsletter-cta-button-text">{buttonText}</span>
        <svg
          class="newsletter-cta-spinner"
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <circle
            cx="8"
            cy="8"
            r="6"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-dasharray="16 10"
            stroke-dashoffset="0"
            class="spinner-circle"></circle>
        </svg>
      </button>
    </div>
    <div class="newsletter-cta-message" role="status" aria-live="polite"></div>
  </form>
</div>

<script>
  async function parseJsonSafely(response: Response) {
    try {
      return await response.json();
    } catch {
      return {};
    }
  }

  document.querySelectorAll('[data-newsletter-form]').forEach((formElement) => {
    const form = formElement as HTMLFormElement;
    const input = form.querySelector('input[type="email"]') as HTMLInputElement | null;
    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const buttonText = button?.querySelector('.newsletter-cta-button-text') as HTMLElement | null;
    const spinner = button?.querySelector('.newsletter-cta-spinner') as SVGElement | null;
    const messageContainer = form.querySelector('.newsletter-cta-message') as HTMLElement | null;
    const defaultButtonText = buttonText?.textContent?.trim() || 'Subscribe';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const email = input?.value.trim();
      if (!email || !button || !buttonText || !messageContainer) return;

      messageContainer.textContent = '';
      messageContainer.className = 'newsletter-cta-message';
      button.disabled = true;
      buttonText.textContent = 'Subscribing...';
      spinner?.classList.add('spinner-spinning');

      try {
        const response = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });

        const data = await parseJsonSafely(response);

        if (response.ok) {
          messageContainer.textContent = data.message || 'Thanks for subscribing.';
          messageContainer.classList.add('newsletter-cta-message--success');
          input.value = '';
          buttonText.textContent = 'Subscribed';
        } else {
          messageContainer.textContent = data.error || 'Something went wrong. Please try again.';
          messageContainer.classList.add('newsletter-cta-message--error');
          button.disabled = false;
          buttonText.textContent = defaultButtonText;
        }
      } catch {
        messageContainer.textContent = 'Network error. Please check your connection and try again.';
        messageContainer.classList.add('newsletter-cta-message--error');
        button.disabled = false;
        buttonText.textContent = defaultButtonText;
      } finally {
        spinner?.classList.remove('spinner-spinning');
      }
    });
  });
</script>

<style>
  .newsletter-cta {
    border-radius: var(--radius-lg);
    padding: clamp(1.35rem, 3vw, 2rem);
    background: rgba(255, 250, 242, 0.76);
    border: 1px solid rgba(182, 164, 143, 0.48);
    box-shadow: var(--shadow-sm);
    backdrop-filter: blur(16px);
  }

  .newsletter-cta-content {
    margin-bottom: var(--spacing-lg);
  }

  .newsletter-cta-title {
    font-size: clamp(1.35rem, 2.4vw, 1.8rem);
    margin-bottom: var(--spacing-sm);
  }

  .newsletter-cta-description {
    font-size: 0.98rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.7;
  }

  .newsletter-cta-form {
    width: 100%;
  }

  .newsletter-cta-input-group {
    display: flex;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .newsletter-cta-input {
    flex: 1;
    min-width: 220px;
    padding: 0.95rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.95rem;
    background-color: var(--color-bg-elevated);
    color: var(--color-text);
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .newsletter-cta-input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-light);
  }

  .newsletter-cta-input::placeholder {
    color: var(--color-text-muted);
  }

  .newsletter-cta-button {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: 0.95rem 1.2rem;
    background-color: var(--color-primary);
    color: #fff7ef;
    border: none;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease;
    white-space: nowrap;
  }

  .newsletter-cta-button:hover:not(:disabled) {
    background-color: var(--color-primary-hover);
    transform: translateY(-1px);
  }

  .newsletter-cta-button:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .newsletter-cta-spinner {
    display: none;
  }

  .spinner-spinning {
    display: block;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  .newsletter-cta-message {
    margin-top: var(--spacing-sm);
    font-size: 0.82rem;
    min-height: 1.25rem;
  }

  .newsletter-cta-message--success {
    color: var(--color-success);
  }

  .newsletter-cta-message--error {
    color: var(--color-error);
  }

  /* Compact variant */
  .newsletter-cta--compact {
    padding: var(--spacing-md);
  }

  .newsletter-cta--compact .newsletter-cta-content {
    margin-bottom: var(--spacing-sm);
  }

  .newsletter-cta--compact .newsletter-cta-title {
    font-size: 1rem;
  }

  .newsletter-cta--compact .newsletter-cta-description {
    font-size: 0.875rem;
  }

  /* Banner variant */
  .newsletter-cta--banner {
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.14), transparent 32%),
      linear-gradient(135deg, var(--color-primary) 0%, #7f2c22 100%);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .newsletter-cta--banner .newsletter-cta-title {
    color: #fff7ef;
  }

  .newsletter-cta--banner .newsletter-cta-description {
    color: rgba(255, 247, 239, 0.88);
  }

  .newsletter-cta--banner .newsletter-cta-input {
    background-color: rgba(255, 247, 239, 0.96);
  }

  /* Minimal variant - for footer */
  .newsletter-cta--minimal {
    padding: 0;
    background: transparent;
    border: none;
    box-shadow: none;
    backdrop-filter: none;
  }

  .newsletter-cta--minimal .newsletter-cta-content {
    display: none;
  }

  .newsletter-cta--minimal .newsletter-cta-form {
    width: 100%;
  }

  .newsletter-cta-invite {
    font-size: 0.74rem;
    color: var(--color-text-muted);
    margin: 0 0 var(--spacing-xs) 0;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .newsletter-cta--minimal .newsletter-cta-input {
    padding: 0.7rem 0.85rem;
    font-size: 0.82rem;
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-elevated);
  }

  .newsletter-cta--minimal .newsletter-cta-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px var(--color-primary-light);
  }

  .newsletter-cta--minimal .newsletter-cta-button {
    padding: 0.7rem 0.95rem;
    font-size: 0.82rem;
  }

  .newsletter-cta--minimal .newsletter-cta-message {
    font-size: 0.75rem;
    margin-top: var(--spacing-xs);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .newsletter-cta-input-group {
      flex-direction: column;
    }

    .newsletter-cta-input,
    .newsletter-cta-button {
      width: 100%;
    }
  }

  :root[data-theme='dark'] .newsletter-cta {
    background: rgba(31, 25, 20, 0.82);
    border-color: rgba(88, 71, 58, 0.8);
  }

  :root[data-theme='dark'] .newsletter-cta--banner {
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.08), transparent 32%),
      linear-gradient(135deg, #c95342 0%, #6f271f 100%);
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme]) .newsletter-cta {
      background: rgba(31, 25, 20, 0.82);
      border-color: rgba(88, 71, 58, 0.8);
    }

    :root:not([data-theme]) .newsletter-cta--banner {
      background:
        radial-gradient(circle at top left, rgba(255, 255, 255, 0.08), transparent 32%),
        linear-gradient(135deg, #c95342 0%, #6f271f 100%);
    }
  }
</style>
