---
const currentYear = new Date().getFullYear();

const footerSections = [
  {
    title: 'Library',
    links: [
      { href: '/patterns', label: 'Browse Patterns' },
      { href: '/graph', label: 'Pattern Graph' },
      { href: '/decision', label: 'Decision Guide' },
      { href: '/guides', label: 'Guides' },
    ],
  },
  {
    title: 'Project',
    links: [
      { href: '/contribute', label: 'Contribute' },
      { href: 'https://github.com/nibzard/awesome-agentic-patterns', label: 'GitHub' },
      { href: 'https://x.com/nibzard', label: 'Twitter' },
    ],
  },
  {
    title: 'Policy',
    links: [
      { href: '/privacy', label: 'Privacy Policy' },
      { href: '/terms', label: 'Terms of Service' },
    ],
  },
];
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-intro">
      <h2 class="footer-headline">A reference surface for teams building agent products.</h2>
      <p class="footer-copy">
        Browse patterns, compare trade-offs, and move from first prototype to production-grade
        agent systems with fewer blind spots.
      </p>
      <div class="footer-actions">
        <a href="/patterns" class="button button--primary">Browse the Library</a>
        <a
          href="https://github.com/nibzard/awesome-agentic-patterns"
          target="_blank"
          rel="noreferrer"
          class="footer-inline-link"
        >
          View repository ↗
        </a>
      </div>
    </div>

    <div class="footer-links">
      {
        footerSections.map((section) => (
          <div class="footer-section">
            <h3 class="footer-section-title">{section.title}</h3>
            <ul class="footer-section-links">
              {section.links.map((link) => (
                <li>
                  <a href={link.href} class="footer-link">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>

  <div class="footer-bottom">
    <p class="footer-copyright">
      &copy; {currentYear} Awesome Agentic Patterns. Built as an open reference for shipping AI
      agents.
    </p>
  </div>
</footer>

<style>
  .footer {
    margin-top: auto;
    border-top: 1px solid var(--color-divider);
    background:
      linear-gradient(180deg, rgba(255, 250, 242, 0.25) 0%, rgba(229, 215, 192, 0.72) 100%);
  }

  .footer-container {
    max-width: var(--page-max);
    margin: 0 auto;
    padding: var(--spacing-3xl) var(--spacing-lg) var(--spacing-2xl);
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  .footer-intro {
    max-width: 38rem;
  }

  .footer-headline {
    margin-top: var(--spacing-md);
    font-size: clamp(2rem, 5vw, 3.4rem);
  }

  .footer-copy {
    margin-top: var(--spacing-lg);
    max-width: 34rem;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .footer-actions {
    margin-top: var(--spacing-xl);
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    flex-wrap: wrap;
  }

  .footer-inline-link {
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .footer-inline-link:hover {
    color: var(--color-primary);
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--spacing-xl);
    padding-top: 0.4rem;
  }

  .footer-section-title {
    margin-bottom: var(--spacing-md);
    color: var(--color-text-muted);
    font-size: 0.76rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .footer-section-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer-link {
    color: var(--color-text);
    font-weight: 500;
  }

  .footer-link:hover {
    color: var(--color-primary);
  }

  .footer-bottom {
    max-width: var(--page-max);
    margin: 0 auto;
    padding: var(--spacing-md) var(--spacing-lg) var(--spacing-xl);
    border-top: 1px solid rgba(182, 164, 143, 0.45);
  }

  .footer-copyright {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.82rem;
  }

  @media (max-width: 960px) {
    .footer-container {
      grid-template-columns: 1fr;
    }

    .footer-links {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .footer-links {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .footer-headline {
      font-size: 2.3rem;
    }
  }
</style>
